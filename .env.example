# ── MustStart Backend Configuration ─────────────────────────
#
# 复制此文件为 .env 并填入你的配置：  cp .env.example .env
# .env 已被 .gitignore 忽略，切勿提交真实密钥。

# ════════════════════════════════════════════════════════════
#  新配置：vivo 蓝心大模型（agent/llm.py 走这套）
# ════════════════════════════════════════════════════════════

# ── vivo 蓝心大模型 (主) ─────────────────────────────────────
# 从 https://aigc.vivo.com.cn/#/platform 获取 AppKey。
# 接口为 OpenAI 协议兼容，鉴权头 Authorization: Bearer <AppKey>。
VIVO_API_KEY=sk-xuanji-xxxxxxxx
# AppId（数字），用于 OCR 的 businessid="aigc"+AppId
VIVO_APP_ID=2026413734
VIVO_API_BASE_URL=https://api-ai.vivo.com.cn/v1
# 可选模型: Volc-DeepSeek-V3.2 | Doubao-Seed-2.0-pro | Doubao-Seed-2.0-lite | qwen3.5-plus
VIVO_MODEL=Volc-DeepSeek-V3.2
# 思考深度: minimal | low | medium | high （意图识别用 low，复杂规划用 high）
VIVO_REASONING_EFFORT=low

# ── LangSmith 链路追踪 (可选，但 demo 强烈建议) ───────────────
# 从 https://smith.langchain.com 获取 API Key。
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=muststart-agent

# ════════════════════════════════════════════════════════════
#  旧配置：可插拔 Provider 系统（已弃用，保留备查 / 回退）
#  新代码不再使用，全部注释；如需回退老路径再取消注释。
# ════════════════════════════════════════════════════════════
#
# Choose your LLM provider by setting LLM_PROVIDER to one of:
#   deepseek         — api.deepseek.com (set DEEPSEEK_API_KEY)
#   nvidia           — integrate.api.nvidia.com (set NVIDIA_API_KEY)
#   openai_compatible — generic (set LLM_BASE_URL, LLM_API_KEY, LLM_MODEL_NAME)
#
# Default is openai_compatible with a local endpoint — good for testing.

# LLM_PROVIDER=openai_compatible

# ── Generic / custom OpenAI-compatible endpoint ──────────────
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL_NAME=deepseek-chat
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7

# ── DeepSeek ────────────────────────────────────────────────
# Uncomment and set LLM_PROVIDER=deepseek to use:
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat

# ── NVIDIA NIM ───────────────────────────────────────────────
# Uncomment and set LLM_PROVIDER=nvidia to use:
# NVIDIA_API_KEY=nvapi-your-nvidia-key-here
# NVIDIA_MODEL=minimaxai/minimax-m2.7
